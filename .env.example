# ============================================================================
# 智能 RAG 问答助手 — 环境变量配置模板
# ============================================================================
# 复制此文件为 .env 并填入你的配置:
#   cp .env.example .env
# ============================================================================

# -------------------------------------------------------------------
# LLM 配置（DeepSeek 默认）
# -------------------------------------------------------------------
# 本项目默认使用 DeepSeek Chat 模型（通过 OpenAI 兼容 API 调用）。
# 也可替换为任何 OpenAI 兼容的 API（GPT、通义千问、GLM 等）。

# DeepSeek API Key（推荐）
DEEPSEEK_API_KEY=sk-xxxx

# DeepSeek API 地址（默认即可）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 备选：OpenAI API Key（当 DEEPSEEK_API_KEY 未设置时使用）
# OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM 模型名
#   - DeepSeek: deepseek-chat (默认) / deepseek-reasoner
#   - OpenAI:   gpt-4o-mini / gpt-4o / gpt-4-turbo
#   - Ollama:   llama3 / qwen2 / qwen2.5
LLM_MODEL=deepseek-chat

# 生成参数
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# -------------------------------------------------------------------
# Embedding 配置
# -------------------------------------------------------------------
# 注意: DeepSeek 不提供原生嵌入 API，请使用本地模型或兼容的嵌入服务。

# 嵌入后端: local / openai / ollama / auto
#   - local:   sentence-transformers 本地模型（默认推荐，可离线使用）
#   - openai:  OpenAI 兼容嵌入 API（如 text-embedding-3-small 等）
#   - ollama:  Ollama 本地嵌入（需启动 ollama serve）
#   - auto:    自动检测（优先 local → openai → ollama）
EMBEDDING_PROVIDER=local

# 嵌入模型名
#   - Local: all-MiniLM-L6-v2 (默认) / BAAI/bge-small-zh-v1.5 / shibing624/text2vec-base-chinese
#   - OpenAI 兼容: text-embedding-3-small / text-embedding-3-large
#   - Ollama: nomic-embed-text / mxbai-embed-large
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenAI 兼容嵌入 API 配置（仅 EMBEDDING_PROVIDER=openai 时需要）
# OPENAI_API_KEY=sk-your-embedding-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama 服务地址
# OLLAMA_BASE_URL=http://localhost:11434

# 本地嵌入模型参数
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
LOCAL_EMBEDDING_DEVICE=cuda  # cpu / cuda / mps

# -------------------------------------------------------------------
# 分块配置
# -------------------------------------------------------------------

# 分块策略: recursive / semantic / token / markdown_header
CHUNK_STRATEGY=recursive

# 分块大小（字符数）
CHUNK_SIZE=1000

# 分块重叠（字符数）
CHUNK_OVERLAP=200

# Token 分块专用参数
TOKEN_CHUNK_SIZE=512
TOKEN_CHUNK_OVERLAP=50

# 语义分块专用参数
SEMANTIC_MAX_CHUNK_SIZE=2000
SEMANTIC_MIN_CHUNK_SIZE=100

# -------------------------------------------------------------------
# 检索配置
# -------------------------------------------------------------------

# 默认返回的文档块数量
RETRIEVAL_TOP_K=5

# 搜索类型: similarity / mmr
RETRIEVAL_SEARCH_TYPE=similarity

# MMR 参数
MMR_FETCH_K=20
MMR_LAMBDA=0.5

# 混合搜索向量权重（0 纯关键词, 1 纯向量）
HYBRID_ALPHA=0.7

# -------------------------------------------------------------------
# 重排序配置
# -------------------------------------------------------------------

# 是否启用重排序（true / false）
RERANK_ENABLED=true

# 重排序后返回数量
RERANK_TOP_K=3

# 重排序方法: keyword_boost / cross_encoder / cohere_rerank
RERANK_METHOD=cross_encoder

# -------------------------------------------------------------------
# 向量存储配置
# -------------------------------------------------------------------

# 向量数据库持久化路径（默认项目根目录下的 chroma_db/）
VECTOR_STORE_PATH=./chroma_db

# 集合名称
COLLECTION_NAME=rag_documents

# -------------------------------------------------------------------
# 对话配置
# -------------------------------------------------------------------

# 最大对话轮数
MAX_CONVERSATION_ROUNDS=50
